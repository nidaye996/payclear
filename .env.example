# 生产环境变量示例。
# 服务器部署时 deploy.sh 会自动写入 /etc/payclear/payclear.env。

PAYCLEAR_ENV=production

# 生成随机密钥：
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-a-long-random-secret

# 仅用于第一次初始化数据库；管理员创建成功后应删除这两项。
INITIAL_ADMIN_USERNAME=qwe
INITIAL_ADMIN_PASSWORD=replace-with-a-strong-password

# 如果未来放到 Nginx 等反向代理后面，再按需开启。
TRUST_PROXY_HEADERS=false
